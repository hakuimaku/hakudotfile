#!/bin/bash
set -m

# --- CẤU HÌNH LOGGING ---
LOG_DIR="$HOME/Documents/bootlog"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/bootlog_$(date +'%Y-%m-%d_%H-%M-%S').txt"

echo ""
echo ""
echo "=== SYSTEM BOOT LOG: $(date) ===" > "$LOG_FILE"
echo "Log path: $LOG_FILE"

# --- CẤU HÌNH USER ---
IntroVideo="/home/hakuimaku/Videos/intro.mp4"

# Màu sắc
GREEN='\033[0;32m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}┌──────────────────────────────────────────┐${NC}"
echo -e "${CYAN}│      HAKUIMAKU SYSTEM INITIALIZATION     │${NC}"
echo -e "${CYAN}└──────────────────────────────────────────┘${NC}"
echo ""

# --- HÀM 1: RUN TASK (CÓ LOG) ---
run_task() {
    DESC=$1
    CMD=$2
    CHECK_PROC=$3

    if [ -n "$CHECK_PROC" ]; then
        if pgrep -f "$CHECK_PROC" > /dev/null; then
            echo -e "${GREEN}[  OK   ]${NC} Starting ${DESC} (Active)"
            return 0
        fi
    fi

    eval "nohup $CMD > /dev/null 2>> \"$LOG_FILE\" &"
    PID=$!
    
    sleep 0.05
    
    if ps -p $PID > /dev/null; then
        # Vẫn đang chạy -> Tốt (Service)
        echo -e "${GREEN}[  OK   ]${NC} Starting ${DESC}..."
        disown $PID
    else
        # Đã tắt -> Kiểm tra xem tắt do xong việc (0) hay do lỗi (!=0)
        wait $PID
        EXIT_CODE=$?
        if [ $EXIT_CODE -eq 0 ]; then
             echo -e "${GREEN}[ DONE  ]${NC} Starting ${DESC} (Completed)"
        else
             echo -e "${RED}[ ERROR ]${NC} Starting ${DESC}..."
             echo "[CRITICAL ERROR] $(date): '$DESC' failed. Exit code: $EXIT_CODE" >> "$LOG_FILE"
        fi
    fi
    sleep 0.05
}

# --- HÀM 2: RUN TASK SILENT (KHÔNG LOG RÁC) ---
run_task_silent() {
    DESC=$1
    CMD=$2
    CHECK_PROC=$3

    if [ -n "$CHECK_PROC" ]; then
        if pgrep -f "$CHECK_PROC" > /dev/null; then
            echo -e "${GREEN}[  OK   ]${NC} Starting ${DESC} (Active)"
            return 0
        fi
    fi

    eval "nohup $CMD > /dev/null 2>&1 &"
    PID=$!
    
    sleep 0.05
    
    if ps -p $PID > /dev/null; then
        echo -e "${GREEN}[  OK   ]${NC} Starting ${DESC}..."
        disown $PID
    else
        wait $PID
        EXIT_CODE=$?
        if [ $EXIT_CODE -eq 0 ]; then
             echo -e "${GREEN}[ DONE  ]${NC} Starting ${DESC} (Completed)"
        else
             echo -e "${RED}[ ERROR ]${NC} Starting ${DESC}..."
             echo "[STARTUP FAIL] $(date): '$DESC' failed silently. Exit code: $EXIT_CODE" >> "$LOG_FILE"
        fi
    fi
    sleep 0.05
}

# --- 1. CORE SYSTEM ---
run_task "DBus Systemd" "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP"
run_task "XDG Portal Hyprland" "/usr/lib/xdg-desktop-portal-hyprland" "xdg-desktop-portal-hyprland"
run_task "XDG Portal KDE" "/usr/lib/xdg-desktop-portal-kde" "xdg-desktop-portal-kde"
run_task "Polkit Agent" "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
run_task "XHost Permissions" "xhost +SI:localuser:root"

# --- 2. BACKGROUND UTILITIES ---
run_task_silent "Idle Manager" "$HOME/.local/bin/idle.sh"
run_task_silent "HyprIdle Service" "hypridle"
run_task_silent "Idle Toggle" "$HOME/.local/bin/idle.sh"
run_task_silent "Audio Idle Inhibit" "sway-audio-idle-inhibit"
run_task_silent "BlueLight Filter" "hyprsunset --temperature 2800"
run_task_silent "Cliphist (Text)" "wl-paste --type text --watch cliphist store"
run_task_silent "Cliphist (Image)" "wl-paste --type image --watch cliphist store"
run_task_silent "Fcitx5 (UniKey)" "fcitx5 -d" "fcitx5"
run_task_silent "Cava AutoHide" "$HOME/.local/bin/cava_autohide.sh"
run_task_silent "Network Applet" "nm-applet --indicator" "nm-applet"
run_task_silent "Wallpaper" "swww-daemon" "swww-daemon"
run_task_silent "Waybar" "waybar" "waybar"
run_task_silent "Notification" "swaync" "swaync"

# --- 3. WAITING USER INPUT ---
echo ""
echo -e "${CYAN}--------------------------------------------${NC}"
echo -e "${GREEN}  SYSTEM CORE READY.${NC}"
echo -e "  Initializing Graphical Interface..."
echo -e "${CYAN}--------------------------------------------${NC}"

for i in {10..1}; do
    echo -ne "  Closing in: $i... \r"
    if read -t 1 -n 1 -s; then break; fi
done

echo -e "\n${GREEN}[ START ]${NC} Starting Desktop Environment..."

# --- 4. THE SEQUENCE ---
(
    mpv --fs --ontop --no-osc --no-osd-bar --keep-open=no --on-all-workspaces --no-input-default-bindings "$IntroVideo" > /dev/null 2>&1 &
    
    MPV_PID=$!
    sleep 0.5
    wait $MPV_PID

    # Optional scripts after intro
    "$HOME/.local/bin/welcome.sh" >> "$LOG_FILE" 2>&1
    "$HOME/.local/bin/toggle_cava.sh" >> "$LOG_FILE" 2>&1
    "$HOME/.local/bin/haku" > /dev/null 2>&1 &
    
    sleep 0.5

    hyprctl dispatch workspace 2
) > /dev/null 2>&1 & 

disown $!

echo "=== BOOT SEQUENCE FINISHED: $(date) ===" >> "$LOG_FILE"
hyprctl dispatch closewindow class:system_start
exit 0