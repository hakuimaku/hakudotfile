#!/bin/bash

# --- CẤU HÌNH ---
# Trỏ đúng vào thư mục chứa file docker-compose.yml trên ổ Shared Data của bro
COMPOSE_PATH="/mnt/Data/mssql_shared"
CONTAINER_NAME="mssql_muses_server"

# Chuyển đến thư mục làm việc
cd "$COMPOSE_PATH" || { notify-send "Error" "Không tìm thấy ổ Shared Data!"; exit 1; }

# Kiểm tra trạng thái container
IS_RUNNING=$(sudo docker ps -q -f name="^${CONTAINER_NAME}$")

if [ -n "$IS_RUNNING" ]; then
    # TRƯỜNG HỢP 1: ĐANG CHẠY -> TẮT (Dùng down để an toàn cho NTFS)
    notify-send "MSSQL Server" "Syncing data & Stopping..." -i database-locked
    sudo docker compose down
    notify-send "MSSQL Server" "Safe to switch OS now!" -i database-fail
else
    # TRƯỜNG HỢP 2: ĐANG TẮT -> BẬT
    notify-send "MSSQL Server" "Starting Muses DB Server..." -i database
    sudo docker compose up -d
    
    if [ $? -eq 0 ]; then
        notify-send "MSSQL Server" "Running on port 1433" -i database-check
    else
        notify-send "MSSQL Server" "Error! Check your mount point." -i dialog-error
    fi
fi