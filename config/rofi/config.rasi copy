configuration {
    font: "JetBrainsMono Nerd Font 12";
    modi: "drun,run,window";
    icon-theme: "Papirus";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-drun: "   Apps ";
    display-run: "   Run ";
    sidebar-mode: true;
}

//@theme "/dev/null"

* {
    /* Màu chủ đạo*/
    accent: #FF003C;
    
    /* Nền đen than (Charcoal) với độ trong suốt 0.3 */
    bg: rgba(18, 18, 18, 0.9); 

    /* text color */    
    fg: #00FFFF; 

    background-color: transparent;
    text-color: @fg;
    margin: 0;
    padding: 0;
    spacing: 0;
}

window {
    width: 35%;
    background-color: @bg;
    border: 1.5px;
    border-color: @accent;
    border-radius: 12px;
}

inputbar {
    children: [prompt, entry];
    /* Thanh nhập liệu tối hơn một chút để tạo chiều sâu */
    background-color: rgba(0, 0, 0, 0.2); 
    border-radius: 8px;
    margin: 10px;
}

prompt {
    padding: 10px;
    background-color: @accent;
    text-color: #121212; /* Chữ trong nút màu đen than cho dễ đọc */
    border-radius: 8px;
    font-weight: bold;
}

entry {
    padding: 10px;
    text-color: @accent;
}

element {
    padding: 10px;
    margin: 2px 10px;
    border-radius: 6px;
}

element selected {
    /* Khi chọn ứng dụng: nền hồng nhạt trong suốt và chữ hồng đậm */
    background-color: rgba(243, 139, 168, 0.15);
    text-color: @accent;
    border: 1px;
    border-color: @accent;
}

element-icon {
    size: 24px;
    margin: 0 10px 0 0;
}

